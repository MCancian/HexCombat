{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hexcombat.llm_observation",
  "title": "HexCombat LLM Observation",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "scenario",
    "turn",
    "phase",
    "turn_length_days",
    "perspective_team",
    "rules_summary",
    "field_glossary",
    "map_summary",
    "brigades",
    "occupied_hexes",
    "legal_moves",
    "legal_commits",
    "pending_orders",
    "pending_commitments",
    "last_contested_hexes",
    "last_combat",
    "objectives"
  ],
  "properties": {
    "protocol_version": {"type": "string"},
    "schema": {"const": "hexcombat.llm_observation"},
    "scenario": {"type": "string"},
    "turn": {"type": "integer"},
    "phase": {"enum": ["planning", "resolution", "end", "unknown"]},
    "turn_length_days": {"type": "integer"},
    "perspective_team": {"type": "string"},
    "rules_summary": {"type": "object"},
    "field_glossary": {"type": "object"},
    "map_summary": {"type": "object"},
    "brigades": {"type": "array"},
    "occupied_hexes": {"type": "array"},
    "legal_moves": {"type": "object"},
    "legal_commits": {"type": "object"},
    "pending_orders": {"type": "object"},
    "pending_commitments": {"type": "object"},
    "last_contested_hexes": {"type": "array"},
    "last_combat": {"type": "array"},
    "objectives": {"type": "array"}
  },
  "additionalProperties": true
}
