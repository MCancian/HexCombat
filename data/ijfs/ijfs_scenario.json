{
  "china_isr_pools": {
    "isr_capacity_cap": 1.5,
    "isr_capacity_rule": "ISR capacity = sqrt((alive aircraft * ISR allocation fraction) / baseline_isr_aircraft), capped by isr_capacity_cap. Baseline defaults preserve legacy Day-1 detection at 100 aircraft with 50% ISR allocation.",
    "manned_aircraft": {
      "allocation_default": {
        "isr": 0.5,
        "sead": 0.25,
        "strike": 0.25
      },
      "baseline_isr_aircraft": 50,
      "health_default": 1.0,
      "initial_assigned_to_ground_support": 100,
      "notes": "Aircraft count and allocation affect ISR capacity with diminishing returns; attrition carries forward by day."
    },
    "satellite_floor": {
      "cannot_be_destroyed": true,
      "handled_in_detection_model": true
    },
    "target_type_isr_weights": {
      "Anti-Ship Systems": {
        "manned_aircraft": 0.4,
        "uav": 0.6
      },
      "Maneuver Units": {
        "manned_aircraft": 0.5,
        "uav": 0.5
      },
      "Mobile Radars": {
        "manned_aircraft": 0.6,
        "uav": 0.4
      },
      "Moveable SAMs": {
        "manned_aircraft": 0.4,
        "uav": 0.6
      },
      "default": {
        "manned_aircraft": 0.5,
        "uav": 0.5
      }
    },
    "uav": {
      "allocation_default": {
        "isr": 0.5,
        "sead": 0.25,
        "strike": 0.25
      },
      "baseline_isr_aircraft": 50,
      "health_default": 1.0,
      "initial_assigned_to_ground_support": 100,
      "notes": "Aircraft count and allocation affect ISR capacity with diminishing returns; attrition carries forward by day."
    }
  },
  "detection_model": {
    "detectability_label_base_probability": {
      "high": 0.5,
      "low": 0.05,
      "medium": 0.2
    },
    "final_probability_rule": "For each target instance: P_detect = min(1.0, satellite_floor + base_probability_from_detectability_label * mobility_multiplier * posture_multiplier * weighted_ISR_health_for_target_type). Then draw one random number per target instance.",
    "antiship_active_attempt_multiplier": 1.5,
    "mobility_multiplier": {
      "mobile": 1.0,
      "moveable": 1.2
    },
    "posture_multiplier": {
      "mobile": {
        "active": 1.25,
        "hiding": 1.0
      },
      "moveable": {
        "active": 1.5,
        "hiding": 1.0
      }
    },
    "satellite_floor_probability": {
      "mobile": {
        "active": 0.02,
        "hiding": 0.01
      },
      "moveable": {
        "active": 0.95,
        "hiding": 0.5
      }
    },
    "static_target_rule": "Static targets are known_to_red=true and detected_this_turn=true unless destroyed; they do not use this probability calculation."
  },
