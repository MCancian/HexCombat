{
  "name": "BOOTS Starter - Northern Beachhead",
  "description": "4 PLA amphibious brigades start at sea in the ship reserve for full offload. 4 ROC brigades defend the adjacent inland hexes. red_ship_reserve beach_hex + offset_bearing preserve each PLA brigade's landing target and seaward render offset for offload landing.",
  "turn_length_days": 1,
  "red_dos_start": 100,
  "feba_base_km": 3.5,
  "red_out_of_supply_effectiveness": 0.5,
  "unscreened_support_strength": 0.5,
  "maneuver_casualty_weight": 4.0,
  "support_casualty_weight": 1.0,
  "stacking_soft_cap": 6,
  "_followon_comment": "auto_seed_followon_pool opts this scenario into the deep mainland pool: with no explicit red_followon_reserve, the pool auto-seeds from the OOB (every RED brigade not in red_ship_reserve), round-robin across the first-wave beaches. Sustained sealift is gated by amphibious lift capacity + the return cycle, not by pool size. scenario_golden omits this flag and stays a one-shot assault.",
  "auto_seed_followon_pool": true,
  "amphibious_return_time_turns": 3,
  "_offload_weights_comment": "use_offload_weight_matrix applies data/offload_weights.json (per-type transport weight x bn_class/ship_category multipliers) to day-N offload costs. scenario_golden omits this flag and keeps the flat TONS_PER_BN cost.",
  "use_offload_weight_matrix": true,
  "_jlsf_comment": "auto_jlsf: every newly seized port/airbridge auto-queues a JLSF logistics deployment (jlsf_lift_bn_equiv BN-equiv of amphibious lift, attritable in the crossing) that repairs it seized->degraded->operational. Explicit deploy_jlsf orders work regardless of this flag.",
  "auto_jlsf": true,
  "victory": {
    "_comment": "End-of-cleanup victory census of battalions ON TAIWAN. loss_check_arm: 'unconditional' (default) | 'after_first_landing' | 'after_turn:<N>'. taiwan_hexes: null counts ALL placed hexes (correct for this main-island scenario; offshore islands can't be distinguished until terrain/land data exists \u2014 see PLAN.md Victory conditions); set to a hex-id array to restrict the census.",
    "loss_check_arm": "after_first_landing",
    "taiwan_hexes": null
  },
